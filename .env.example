# Google Cloud / Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# Arize Phoenix (Cloud)
PHOENIX_API_KEY=your-phoenix-api-key-here
